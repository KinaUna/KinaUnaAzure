# =============================================================================
# KinaUna Docker Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values before running docker compose.
#   Copy-Item .env.example .env
#
# IMPORTANT: Never commit the .env file to source control.
# =============================================================================

# --- HTTPS / Kestrel Certificate ---
# A single self-signed certificate is used by all three services for Kestrel HTTPS.
# It must cover both 'localhost' AND 'host.docker.internal' as Subject Alternative Names so that:
#   - Your browser (on the Windows host) can reach https://host.docker.internal:PORT
#   - Docker containers can also reach each other at the same https://host.docker.internal:PORT URLs
#     (host.docker.internal resolves to the host machine from inside Docker on Windows/Mac)
#
# Generate the certificate once with PowerShell (run as the current user, not as admin):
#
#   mkdir certs
#   $pwd = ConvertTo-SecureString -String "YourKestrelCertPassword" -Force -AsPlainText
#   $cert = New-SelfSignedCertificate `
#       -DnsName "localhost", "host.docker.internal" `
#       -CertStoreLocation "cert:\CurrentUser\My" `
#       -KeyUsage DigitalSignature `
#       -NotAfter (Get-Date).AddYears(5)
#   Export-PfxCertificate -Cert $cert -FilePath ".\certs\aspnetapp.pfx" -Password $pwd
#   # Trust the certificate in your browser (adds to Current User Trusted Root store):
#   $rootStore = New-Object System.Security.Cryptography.X509Certificates.X509Store -ArgumentList 'Root','CurrentUser'
#   $rootStore.Open('ReadWrite')
#   $rootStore.Add($cert)
#   $rootStore.Close()
#
# Set the password you chose above:
# NOTE: The docker-entrypoint.sh script automatically extracts the public certificate
# from this PFX and adds it to each container's trusted CA store at startup, so that
# inter-service HTTPS calls (e.g., token requests to the auth server) succeed.
KESTREL_CERT_PASSWORD=YourKestrelCertPassword

# --- Database Connection Strings ---
PROGENY_DB_CONNECTION=Host=host.docker.internal;Port=5432;Database=kinaunaprogeny;Username=YourUsername;Password=YourPassword
MEDIA_DB_CONNECTION=Host=host.docker.internal;Port=5432;Database=kinaunamedia;Username=YourUsername;Password=YourPassword
AUTH_DB_CONNECTION=Host=host.docker.internal;Port=5432;Database=kinaunaauth;Username=YourUsername;Password=YourPassword


# --- OpenIddict signing/encryption certificate files ---
# Place encryption.pfx and signing.pfx in the ./certs/ directory.
# The auth server needs both; the API server needs the encryption certificate only.
ENCRYPTION_CERT_PASSWORD=
SIGNING_CERT_PASSWORD=

# Thumbprints are required by the config schema but unused when PFX paths are set.
SERVER_ENCRYPTION_CERT_THUMBPRINT=docker-placeholder
SERVER_SIGNING_CERT_THUMBPRINT=docker-placeholder

# --- Service URLs ---
# host.docker.internal is used so both the browser (on the Windows host) and Docker containers
# can reach every service at the same address, keeping the OpenIddict token issuer URL consistent.
AUTH_SERVER_URL=https://host.docker.internal:5000
WEB_SERVER_URL=https://host.docker.internal:5002
PROGENY_API_URL=https://host.docker.internal:5001

# --- CORS Origins (semicolon-separated, merged with hardcoded lists) ---
CORS_ORIGINS=https://host.docker.internal:5000;https://host.docker.internal:5001;https://host.docker.internal:5002

# --- OpenIddict Client IDs ---
# These must match the values configured in the OpenIddict seeder.
AUTH_SERVER_CLIENT_ID=kinaunaauthclient
AUTH_API_CLIENT_ID=kinaunaauthapiclient
AUTH_API_ONLY_CLIENT_ID=kinaunaauthapionlyclient
WEB_SERVER_CLIENT_ID=kinaunawebclient
WEB_SERVER_API_CLIENT_ID=kinaunawebapiclient
PROGENY_API_CLIENT_ID=kinaunaprogenyapiclient

# --- OpenIddict Client Secrets ---
# The OpenIddict seeder registers clients for all environments (base, Local, Azure) simultaneously.
# In Docker all three variants share the same value — docker-compose maps them automatically.
AUTH_CLIENT_SECRET=
WEB_SERVER_CLIENT_SECRET=
PROGENY_API_CLIENT_SECRET=

# --- OpenIddict Database ---
# Set to true on first run to seed the OpenIddict database with client configurations.
RESET_OPENIDDICT_DATABASE=false

# --- Admin ---
ADMIN_EMAIL=

# --- SMTP / Email ---
SMTP_SERVER=smtp.office365.com
SMTP_USERNAME=
SMTP_FROM=
SUPPORT_MAIL_PASSWORD=

# --- VAPID Keys (Web Push Notifications) ---
# Generate with the GenerateKeys action in WebPushController (admin only).
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# --- Here Maps (used by KinaUnaWeb for location pages) ---
HERE_MAPS_ID=
HERE_MAPS_KEY=

# --- Syncfusion (used by KinaUnaWeb for rich-text editor) ---
SYNCFUSION_KEY=

# --- SEQ Configuration
SEQ_ADMIN_PASSWORD=
SEQ_URL=http://seq:5341
