@using KinaUna.Data
@using KinaUnaWeb.Services
@model KinaUnaWeb.Models.Search.SearchViewModel
@inject ILocaleManager LocaleManager
@{
    string title = await LocaleManager.GetTranslation("Quick-Search", PageNames.Layout, Model.LanguageId);
    string searchString = await LocaleManager.GetTranslation("Search", PageNames.Layout, Model.LanguageId);
    string searchPlaceholder = await LocaleManager.GetTranslation("Enter search terms...", PageNames.Layout, Model.LanguageId);
}
<div class="full-screen-bg">
    <div class="space-50"></div>
    <div class="ml-auto mr-auto mt-auto mb-auto item-details-content-wrapper">
        <div class="timeline-card-body modal-content item-details-content">
            <div class="row sticky-top m-0 item-details-header">
                <div class="col-12 bg-add-item-header">
                    <span class="h4 mr-3 align-bottom">@title</span>
                    <button id="quick-search-close-button" type="button" class="btn btn-link quick-search-close-button"><span>×</span></button>
                </div>
            </div>
            <form id="quick-search-form">
                <div class="space-20"></div>
                @* Search Input *@
                <div class="row m-0">
                    <div class="col-12">
                        <div class="input-group">
                            <input id="quick-search-query-input" class="form-control form-control-lg"
                                   placeholder="@searchPlaceholder"
                                   aria-label="@searchString"/>
                            <div class="input-group-append">
                                <button type="submit" class="btn btn-primary m-0">
                                    <i class="material-icons icon-top-4">search</i> @searchString
                                </button>
                            </div>
                        </div>
                    </div>
                    <div class="col-12">
                        <a class="btn btn-link float-right" asp-controller="Search" asp-action="Index">
                            <i class="material-icons">manage_search</i> @await LocaleManager.GetTranslation("Advanced Search", PageNames.Layout, Model.LanguageId)
                        </a>
                    </div>
                </div>
                <div class="space-20"></div>
            </form>
            <div class="row m-0" style="max-height: 70vh;">
                <div class="col-12">
                    <div id="quick-search-results-div" class="row m-0"></div>
                    <div class="row" style="height: 150px;">
                        <button id="more-quick-search-results-button" class="btn btn-link btn-link-edit d-none" style="margin-top: 20px;">@await LocaleManager.GetTranslation("Show more posts", PageNames.Timeline, Model.LanguageId)</button>
                        <div id="loading-quick-search-results-div" class="w-100">
                            <div class="space-50"></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="space-50"></div>
</div>

