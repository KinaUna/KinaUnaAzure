@using KinaUnaWeb.Services
@using KinaUna.Data
@model KinaUnaWeb.Models.ItemViewModels.MeasurementViewModel
@inject ILocaleManager LocaleManager
@{
    ViewData["Title"] = await LocaleManager.GetTranslation("Add measurement", PageNames.Measurements, Model.LanguageId);
    string addMeasurementForString = await LocaleManager.GetTranslation("Add measurement for:", PageNames.Measurements, Model.LanguageId);
    const string zebraDateTimeFormat = "d-F-Y";
    const string longDateTimeFormat = "dd-MMMM-yyyy";
    int permissionsDataType = (int)KinaUnaTypes.TimeLineType.Measurement;
}
<div id="current-moment-locale-div" class="d-none" data-current-locale="@Model.LanguageIdString"></div>
<div id="add-measurement-zebra-date-time-format-div" class="d-none" data-zebra-date-time-format="@zebraDateTimeFormat"></div>
<div class="ml-auto mr-auto mt-auto mb-auto item-details-content-wrapper">
    <div class="timeline-card-body modal-content item-details-content">
        <div class="row sticky-top m-0 item-details-header">
            <div class="col-12 bg-add-item-header">
                <span class="h4 mr-3 align-bottom">@ViewData["Title"]</span>
                <button type="button" class="btn btn-link item-details-close-button"><span>×</span></button>
            </div>
        </div>
        <form id="save-item-form" asp-action="AddMeasurement" asp-controller="Measurements" role="form" method="post">
            <div class="space-20"></div>
            <div class="form-group d-none">
                <label class="col-auto control-label">@addMeasurementForString</label>
                <div class="col-auto">
                    <button id="add-item-for-individual-button" class="btn btn-primary" type="button">Individual</button>
                    <button id="add-item-for-family-button" class="btn btn-outline-primary" type="button">Family</button>
                </div>
            </div>
            @if (Model.ProgenyList.Count > 0)
            {
                <div id="individual-select-from-group" class="form-group">
                    <label asp-for="MeasurementItem.ProgenyId" class="col-auto control-label">@addMeasurementForString </label>
                    <div class="col-auto">
                        <select id="item-progeny-id-select" class="selectpicker form-control-noline" data-style="btn-kinaunaselect" data-size="@Model.ProgenyList.Count" asp-for="MeasurementItem.ProgenyId" asp-items="@Model.ProgenyList"></select>
                    </div>
                </div>
            }
            <div class="form-group">
                <label asp-for="MeasurementItem.Date" class="col-auto control-label">@await LocaleManager.GetTranslation("Date", PageNames.Measurements, Model.LanguageId)</label>
                <div class="col-auto">
                    <div class="input-group date">
                        <input id="measurement-date-time-picker" type="text"
                               class="form-control" data-zdp_readonly_element="false" asp-for="MeasurementItem.Date" value="@Model.MeasurementItem.Date.ToString(longDateTimeFormat)" />
                    </div>
                </div>
            </div>
            <div class="form-group">
                <label asp-for="MeasurementItem.Height" class="col-auto control-label">@await LocaleManager.GetTranslation("Height", PageNames.Measurements, Model.LanguageId)</label>
                <div class="col-auto">
                    <input asp-for="MeasurementItem.Height" class="form-control"/>
                </div>
            </div>
            <div class="form-group">
                <label asp-for="MeasurementItem.Weight" class="col-auto control-label">@await LocaleManager.GetTranslation("Weight", PageNames.Measurements, Model.LanguageId)</label>
                <div class="col-auto">
                    <input asp-for="MeasurementItem.Weight" class="form-control"/>
                </div>
            </div>
            <div class="form-group">
                <label asp-for="MeasurementItem.Circumference" class="col-auto control-label">@await LocaleManager.GetTranslation("Circumference", PageNames.Measurements, Model.LanguageId)</label>
                <div class="col-auto">
                    <input asp-for="MeasurementItem.Circumference" class="form-control"/>
                </div>
            </div>
            <div class="form-group">
                <label asp-for="MeasurementItem.HairColor" class="col-auto control-label">@await LocaleManager.GetTranslation("Hair color", PageNames.Measurements, Model.LanguageId)</label>
                <div class="col-auto">
                    <input asp-for="MeasurementItem.HairColor" class="form-control"/>
                </div>
            </div>
            <div class="form-group">
                <label asp-for="MeasurementItem.EyeColor" class="col-auto control-label">@await LocaleManager.GetTranslation("Eye color", PageNames.Measurements, Model.LanguageId)</label>
                <div class="col-auto">
                    <input asp-for="MeasurementItem.EyeColor" class="form-control"/>
                </div>
            </div>
            <div id="item-permissions-editor-div" class="d-none" data-item-type="@permissionsDataType" data-item-id="@Model.MeasurementItem.MeasurementId"></div>
            <input id="item-permissions-list-as-string-input" asp-for="ItemPermissionsListAsString" value="@Model.ItemPermissionsListAsString" type="hidden"/>
            <input id="inherit-permissions-input" asp-for="InheritPermissions" value="@Model.InheritPermissions" type="hidden"/>
            <div class="space-20"></div>
            <div>
                <div class="form-group">
                    <div class="col-auto control-label"></div>
                    <div class="col-auto">
                        <button class="btn btn-success" type="submit">@await LocaleManager.GetTranslation("Save", PageNames.AddItem, Model.LanguageId)</button>
                        <a class="btn btn-danger item-details-cancel-button">@await LocaleManager.GetTranslation("Cancel", PageNames.AddItem, Model.LanguageId)</a>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>