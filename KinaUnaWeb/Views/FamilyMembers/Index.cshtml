@model KinaUnaWeb.Models.FamiliesViewModels.FamiliesViewModel
@using KinaUna.Data
@using KinaUna.Data.Models.Family
@using KinaUnaWeb.Services
@inject ILocaleManager LocaleManager
@{
    ViewData["Title"] = await LocaleManager.GetTranslation("Family Members", PageNames.Family, Model.LanguageId);
}
<div class="row m-0">
    <div class="col-12">
        <div class="page-tab-container">
            <div class="page-tab" id="page-title-div">
                <a class="btn-page-tab leave-page" asp-controller="Families" asp-action="Index">
                    <i class="material-icons sidebar-icon">family_restroom</i>@await LocaleManager.GetTranslation("Families", PageNames.Family, Model.LanguageId)
                </a>
            </div>
            <div class="page-tab active">
                <a class="btn-page-tab active leave-page" asp-controller="FamilyMembers" asp-action="Index">
                    <i class="material-icons sidebar-icon">group</i> @ViewData["Title"]
                </a>
            </div>
            <div class="page-tab">
                <a class="btn-page-tab leave-page" asp-controller="FamilyAccess" asp-action="Index">
                    <i class="material-icons sidebar-icon">badge</i> @await LocaleManager.GetTranslation("User Access", PageNames.Family, Model.LanguageId)
                </a>
            </div>
            <div class="page-tab">
                <a class="btn-page-tab leave-page" asp-controller="Progeny" asp-action="OtherPeopleAndPets">
                    <i class="material-icons sidebar-icon">contacts</i> @await LocaleManager.GetTranslation("Other people/pets", PageNames.Family, Model.LanguageId)
                </a>
            </div>
        </div>
    </div>
</div>
<div class="space-50"></div>
@foreach (Family family in Model.Families)
{
    <div class="row m-0">
        <div class="ml-xl-auto mr-xl-auto col-12 col-xxl-11 col-xxxl-10 col-w1900-8 col-w2500-7 bg-page-content">
            <div class="row">
                <div class="col-12">
                    <span class="h4">@family.Name</span>
                    <button id="add-new-family-member-button-@family.FamilyId" data-family-id="@family.FamilyId" class="btn btn-primary float-right add-new-family-member-button"><i class="material-icons icon-top-4">add</i> @await LocaleManager.GetTranslation("Add family member", PageNames.Family, Model.LanguageId)</button>
                </div>
            </div>
            <div class="space-20"></div>
            <div id="family-members-list-div-@family.FamilyId" class="row">
            </div>
        </div>
    </div>
    <div class="space-50"></div>
}
<div id="family-details-div" class="d-none item-details-popup"></div>
<script src="/js/families/family-members-v10.js" type="module" asp-append-version="true"></script>