@using KinaUnaWeb.Services
@using KinaUna.Data
@using KinaUna.Data.Extensions
@model KinaUnaWeb.Models.ItemViewModels.PictureItemViewModel
@inject ILocaleManager LocaleManager
@{
    string title = await LocaleManager.GetTranslation("Delete photo", PageNames.Pictures, Model.LanguageId);
}
<div class="ml-auto mr-auto mt-auto mb-auto item-details-content-wrapper">
    <div class="timeline-card-body bg-body item-details-content">
    <div class="row sticky-top m-0 item-details-header">
            <div class="col-12 bg-body">
            @if (Model.Picture.ProgenyId > 0)
            {
                <img src="@Model.Picture.Progeny.GetProfilePictureUrl()" class="item-details-title-picture" />
            }
            <span class="h4 mr-3 align-bottom">@title</span>
            <button type="button" class="btn btn-link item-details-close-button" data-previous-item-type="picture" data-previous-item-id="@Model.Picture.PictureId"><span>×</span></button>
        </div>
    </div>
    <div class="row m-0">
            <div class="space-20"></div>
            <form id="save-item-form" asp-controller="Pictures" asp-action="DeletePicture" role="form" method="post">
                <div class="col-auto">
                    @await LocaleManager.GetTranslation("Are you sure you want to delete this photo?", PageNames.Pictures, Model.LanguageId)
                </div>
                <div class="col-auto">
                    <img src="@Model.Picture.PictureLink600" class="img-responsive" style="max-width: 600px; width: 90%;" />
                    @if (Model.Picture.PictureTime.HasValue)
                    {
                        <div>@await LocaleManager.GetTranslation("Date and time:", PageNames.Pictures, Model.LanguageId) @Model.Picture.PictureTime.Value.ToString("dd-MMM-yyyy HH:mm")"</div>
                    }
                </div>
                <div class="space-20"></div>
                <input asp-for="Picture.PictureId" class="form-control" value="@Model.Picture.PictureId" type="hidden" />
                <input asp-for="Picture.ProgenyId" class="form-control" value="@Model.Picture.ProgenyId" type="hidden" />
                <div class="col-auto">
                    <Button type="submit" class="btn btn-success leave-page">@await LocaleManager.GetTranslation("Yes - delete this photo", PageNames.Pictures, Model.LanguageId)</Button>
                    <Button type="button" data-previous-item-type="picture" data-previous-item-id="@Model.Picture.PictureId" class="item-details-cancel-button btn btn-danger leave-page">@await LocaleManager.GetTranslation("Cancel", PageNames.AddItem, Model.LanguageId)</Button>
                </div>
            </form>
    </div>
    </div>
</div>