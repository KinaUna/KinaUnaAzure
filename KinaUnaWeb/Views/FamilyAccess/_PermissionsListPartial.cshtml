@using KinaUna.Data.Extensions
@using KinaUna.Data.Models.AccessManagement
@using KinaUna.Data.Models.Family
@using KinaUnaWeb.Models.FamilyAccessViewModels
@using KinaUnaWeb.Services
@model UserGroupsViewModel
@inject ILocaleManager LocaleManager
<div class="row m-0">
    <div class="col-12 h-4">
        Family Access
    </div>
    @foreach (Family family in Model.Families)
    {
        <div class="col-12 mt-3 mb-1 h4">
            <i class="material-icons kinauna-icon-medium" style="font-size: 32px">family_restroom</i> @family.Name
        </div>
        <div class="col-12 h5">Group permissions</div>
        <div class="col-12">
            <button class="add-group-button" data-progeny-id="0" data-family-id="@family.FamilyId">Add new group</button>
        </div>
        @foreach (UserGroup userGroup in Model.UserGroups)
        {
            if (userGroup.FamilyId == family.FamilyId)
            {
                <div class="col-12">
                    <span>Group name: @userGroup.Name</span><span>Permission: @userGroup.PermissionLevel.ToString()</span>
                    <button class="add-group-member-button" data-group-id="@userGroup.UserGroupId">Add member</button>
                    <button class="edit-group-button" data-edit-group-id="@userGroup.UserGroupId">Edit</button>
                    <button class="delete-group-button" data-delete-group-id="@userGroup.UserGroupId">Delete</button>
                </div>
                <div class="col-12">
                    Members:
                    <div class="row">
                        @foreach (UserGroupMember userGroupMember in userGroup.Members)
                        {
                            <div class="col-12">
                                <span>Email: @userGroupMember.Email</span>
                                @if (userGroupMember.UserInfo != null)
                                {
                                    <span> @userGroupMember.UserInfo.FullName()</span>
                                }
                            </div>
                            <div class="col-12">
                                <button class="edit-user-group-member-button" data-edit-user-group-member-id="@userGroupMember.UserGroupMemberId">Edit</button>
                                <button class="delete-user-group-member-button" data-delete-user-group-member-id="@userGroupMember.UserGroupMemberId">Delete</button>
                            </div>
                        }
                    </div>
                </div>
            }
        }

        <div class="col-12 h5">User permissions</div>
        <div class="col-12">
            <button class="add-user-button" data-progeny-id="0" data-family-id="@family.FamilyId">Add new user</button>
        </div>
        @foreach (FamilyPermission familyPermission in Model.FamilyPermissions)
        {
            if (familyPermission.FamilyId == family.FamilyId)
            {
                <div class="col-12">
                    <span>Email: @familyPermission.Email</span>
                    @if (!string.IsNullOrWhiteSpace(familyPermission.UserId) && familyPermission.UserInfo != null)
                    {
                        <span> @familyPermission.UserInfo.FullName()</span>
                    }
                </div>
                <div class="col-12">
                    <button class="edit-user-family-permission-button" data-edit-user-family-permission-id="@familyPermission.FamilyPermissionId" data-family-id="@family.FamilyId">Edit</button>
                    <button class="delete-user-family-permission-button" data-delete-user-family-permission-id="@familyPermission.FamilyPermissionId" data-family-id="@family.FamilyId">Delete</button>
                </div>
            }
        }
    }
</div>
<div class="row m-0">
    <div class="col-12 h4">
        Individual Access
    </div>
    @foreach (Progeny progeny in Model.Progenies)
    {
        <div class="col-12 mt-3 mb-1 h4">
            <i class="material-icons kinauna-icon-medium" style="font-size: 32px">family_restroom</i> @progeny.NickName
        </div>
        <div class="col-12 h5">Group permissions</div>
        <div class="col-12">
            <button class="add-group-button" data-progeny-id="@progeny.Id" data-family-id="0">Add new group</button>
        </div>
        @foreach (UserGroup userGroup in Model.UserGroups)
        {
            if (userGroup.ProgenyId == progeny.Id)
            {
                <div class="col-12">
                    <span>Group name: @userGroup.Name</span><span>Permission: @userGroup.PermissionLevel.ToString()</span>
                    <button class="add-group-member-button" data-group-id="@userGroup.UserGroupId">Add member</button>
                    <button class="edit-group-button" data-edit-group-id="@userGroup.UserGroupId">Edit</button>
                    <button class="delete-group-button" data-delete-group-id="@userGroup.UserGroupId">Delete</button>
                </div>
                <div class="col-12">
                    Members:
                    <div class="row">
                        @foreach (UserGroupMember userGroupMember in userGroup.Members)
                        {
                            <div class="col-12">
                                <span>Email: @userGroupMember.Email</span>
                                @if (userGroupMember.UserInfo != null)
                                {
                                    <span> @userGroupMember.UserInfo.FullName()</span>
                                }
                            </div>
                            <div class="col-12">
                                <button class="edit-user-group-member-button" data-edit-user-group-member-id="@userGroupMember.UserGroupMemberId">Edit</button>
                                <button class="delete-user-group-member-button" data-delete-user-group-member-id="@userGroupMember.UserGroupMemberId">Delete</button>
                            </div>
                        }
                    </div>
                </div>
            }
        }

        <div class="col-12 h5">User permissions</div>
        <div class="col-12">
            <button class="add-user-button" data-progeny-id="@progeny.Id" data-family-id="0">Add new user</button>
        </div>
        @foreach (ProgenyPermission progenyPermission in Model.ProgenyPermissions)
        {
            if (progenyPermission.ProgenyId == progeny.Id)
            {
                <div class="col-12">
                    <span>Email: @progenyPermission.Email</span>
                    @if (!string.IsNullOrWhiteSpace(progenyPermission.UserId) && progenyPermission.UserInfo != null)
                    {
                        <span> @progenyPermission.UserInfo.FullName()</span>
                    }
                </div>
                <div class="col-12">
                    <button class="edit-user-progeny-permission-button" data-edit-user-progeny-permission-id="@progenyPermission.ProgenyPermissionId" data-progeny-id="@progeny.Id">Edit</button>
                    <button class="delete-user-progeny-permission-button" data-delete-user-progeny-permission-id="@progenyPermission.ProgenyPermissionId" data-progeny-id="@progeny.Id">Delete</button>
                </div>
            }
        }
    }
</div>