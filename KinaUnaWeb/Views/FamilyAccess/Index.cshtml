@model PermissionsListViewModel
@using KinaUna.Data
@using KinaUnaWeb.Models.FamilyAccessViewModels
@using KinaUnaWeb.Services
@inject ILocaleManager LocaleManager
@{
    ViewData["Title"] = await LocaleManager.GetTranslation("Manage User Access", PageNames.Family, Model.LanguageId);
}
<div class="row m-0">
    <div class="col-12">
        <div class="page-tab-container">
            <div class="page-tab" id="page-title-div">
                <a class="btn-page-tab leave-page" asp-controller="Families" asp-action="Index">
                    <i class="material-icons sidebar-icon">family_restroom</i>@await LocaleManager.GetTranslation("Families", PageNames.Family, Model.LanguageId)
                </a>
            </div>
            <div class="page-tab active">
                <a class="btn-page-tab active leave-page" asp-controller="FamilyAccess" asp-action="Index">
                    <i class="material-icons sidebar-icon">badge</i> @await LocaleManager.GetTranslation("User Access", PageNames.Family, Model.LanguageId)
                </a>
            </div>
            <div class="page-tab">
                <a class="btn-page-tab leave-page" asp-controller="Progeny" asp-action="OtherPeopleAndPets">
                    <i class="material-icons sidebar-icon">contacts</i> @await LocaleManager.GetTranslation("Other people/pets", PageNames.Family, Model.LanguageId)
                </a>
            </div>
        </div>
    </div>
</div>
<div class="row m-0">
    <div id="permissions-list-div" class="col-12"></div>
</div>
<script src="/js/family-access/family-access-index.js" type="module" asp-append-version="true"></script>
