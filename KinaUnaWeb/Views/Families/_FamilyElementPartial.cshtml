@using KinaUna.Data
@using KinaUna.Data.Extensions
@using KinaUna.Data.Models.AccessManagement
@using KinaUna.Data.Models.Family
@using KinaUnaWeb.Services
@model KinaUnaWeb.Models.FamiliesViewModels.FamilyElementViewModel
@inject ILocaleManager LocaleManager
<div class="col-12">
    <div id="family-element-@Model.Family.FamilyId" class="bg-todos todo-item" data-family-id="@Model.Family.FamilyId" align="left">
        @if (Model.Family.FamilyId == 0)
        {
            <div>@await LocaleManager.GetTranslation("Nothing to see here yet.", PageNames.Notes, Model.LanguageId)</div>
        }
        else
        {
            <div class="row ml-0">
                <div class="col mr-0">
                    <button id="family-info-button-@Model.Family.FamilyId" class="float-right btn btn-link" data-family-id="@Model.Family.FamilyId"><i class="material-icons sidebar-icon">info</i></button>
                    <span class="h3"><i class="material-icons sidebar-icon">family_restroom</i> @Model.Family.Name</span>
                </div>
            </div>
            <div class="row m-2">
                @foreach (FamilyMember familyMember in Model.Family.FamilyMembers)
                {
                    <div class="col-12 card bg-dark-50 item-element-button" data-family-member-id="@familyMember.FamilyMemberId" data-family-member-family-id="@familyMember.FamilyId">
                        <div class="row card-body">
                            <div class="col-12">
                                @if (familyMember.ProgenyId != 0 && familyMember.Progeny != null)
                                {
                                    <img src="@familyMember.Progeny.GetProfilePictureUrl()" class="profile-picture-small" />
                                    <span class="h4">@familyMember.Progeny.NickName</span>
                                }
                                <span>[@await LocaleManager.GetTranslation(familyMember.MemberType.ToString(), PageNames.Family, Model.LanguageId)]</span>
                            </div>
                            @if (!string.IsNullOrEmpty(familyMember.Email))
                            {
                                <div class="col-12 ml-4">
                                    <div class="space-10"></div>
                                    <span>Email:</span> <span>@familyMember.Email</span>
                                </div>
                            }
                            @if (!string.IsNullOrWhiteSpace(familyMember.UserId) && familyMember.UserInfo != null)
                            {
                                <div class="col-auto ml-4">
                                    <span>@await LocaleManager.GetTranslation("User Info", PageNames.Account, Model.LanguageId):</span>
                                    <span>@familyMember.UserInfo.FullName()</span>
                                </div>
                            }
                        </div>
                    </div>
                }
                @if (Model.Family.FamilyPermission.PermissionLevel >= PermissionLevel.Edit)
                {
                    <div class="col-12">
                        <button id="add-new-family-member-button-@Model.Family.FamilyId" data-family-id="@Model.Family.FamilyId" class="btn btn-success float-right add-new-family-member-button"><i class="material-icons icon-top-4">add</i> @await LocaleManager.GetTranslation("Add family member", PageNames.Family, Model.LanguageId)</button>
                    </div>
                }
            </div>
        }
    </div>
    <div class="space-20"></div>
</div>

