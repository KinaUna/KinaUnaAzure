@using KinaUna.Data
@using KinaUnaWeb.Services
@model KinaUnaWeb.Models.FamiliesViewModels.FamilyDetailsViewModel
@inject ILocaleManager LocaleManager
@{
    string removeFamilyString = await LocaleManager.GetTranslation("Delete family", PageNames.Family, Model.LanguageId);
}
<div class="ml-auto mr-auto mt-auto mb-auto item-details-content-wrapper">
    <div class="timeline-card-body bg-dark modal-content item-details-content" style="width: fit-content;">
        <div class="row text-white m-0 item-details-header">
            <div class="col-12">
                <div class="space-20">
                </div>
            </div>
            <div class="col-auto">
                <span class="timeline-icon"><i class="material-icons" style="font-size: 48px;">person_remove</i></span>
            </div>
            <div class="col">
                <div class="h4 mr-3 align-bottom">
                    @removeFamilyString
                </div>
            </div>
            <button type="button" class="btn btn-link modal-close-button item-details-close-button family-details-close-button"><span>×</span></button>
        </div>
        <div class="space-50"></div>
        <div class="row m-0">
            <div class="col-12">
                <div class="row m-0">
                    <div class="col-12">
                        <div class="h5">@await LocaleManager.GetTranslation("Family", PageNames.Family, Model.LanguageId): @Model.CurrentFamily.Name</div>
                    </div>
                </div>
            </div>
            <div class="col-12">
                <form id="delete-family-member-form" asp-action="DeleteFamily" asp-controller="Families" role="form" method="post">
                    <div class="space-20"></div>
                    <div class="form-group">
                        <input type="hidden" asp-for="Family.FamilyId" value="@Model.Family.FamilyId" />
                        <div class="col">
                            <button id="save-family-member-submit-button" type="submit" class="btn btn-success">@removeFamilyString</button>
                            <button type="button" class="btn btn-danger family-details-close-button">@await LocaleManager.GetTranslation("Cancel", PageNames.AddItem, Model.LanguageId)</button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>