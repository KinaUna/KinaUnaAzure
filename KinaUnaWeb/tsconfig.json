{
  "compileOnSave": true,
  "compilerOptions": {
    "disableSizeLimit": true,
    "lib": [ "es2020", "dom" ],
    "module": "ES2020",
    "moduleResolution": "bundler",
    "noEmitOnError": true,
    "noImplicitAny": true,
    "outDir": "wwwroot/js",
    "removeComments": false,
    "rootDir": "./Scripts",
    "skipLibCheck": true,
    "sourceMap": true,
    "strict": true,
    "target": "ES2020",
    "types": [ "jquery", "bootstrap", "datatables.net", "heremaps", "node" ]
  },
  "exclude": [
    "**/node_modules",
    "**.nuget/**/*",
    "wwwroot"
  ],
  "include": [
    "Scripts/**/*"
  ]
}